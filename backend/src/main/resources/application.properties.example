# Copy this file to application.properties for local development and fill in real values.
# For Railway: set these as environment variables in the Railway dashboard instead.

# ── Required (no defaults) ───────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://your-host:6543/postgres?sslmode=require&prepareThreshold=0
SPRING_DATASOURCE_USERNAME=postgres.your_project_ref
SPRING_DATASOURCE_PASSWORD=your_db_password
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWKSETURI=https://your_project_ref.supabase.co/auth/v1/.well-known/jwks.json
APP_SUPABASE_URL=https://your_project_ref.supabase.co
APP_SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Required for production ──────────────────────────────────────────────────
DDL_AUTO=validate
CORS_ORIGINS=https://your-vercel-app.vercel.app

# ── Optional (defaults shown) ────────────────────────────────────────────────
# APP_STORAGE_BUCKET=stitchbud-files
# APP_UPLOAD_DIR=./uploads
# PORT=8080  (Railway sets this automatically)
